<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vorenth Intelligence Platform</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            vorenth: {
              dark: '#0a0f1a',
              darker: '#060a12',
              card: '#111827',
              border: '#1f2937',
              accent: '#06b6d4',
              accentHover: '#0891b2',
              success: '#10b981',
              warning: '#f59e0b',
              danger: '#ef4444',
              muted: '#6b7280',
              text: '#e5e7eb'
            }
          }
        }
      }
    }
  </script>
  <style>
    * { font-family: 'Space Grotesk', sans-serif; }
    .mono { font-family: 'JetBrains Mono', monospace; }

    .gradient-mesh {
      background: 
        radial-gradient(ellipse at 20% 20%, rgba(6, 182, 212, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(16, 185, 129, 0.05) 0%, transparent 70%),
        linear-gradient(180deg, #0a0f1a 0%, #060a12 100%);
    }

    .glass-card {
      background: rgba(17, 24, 39, 0.8);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(31, 41, 55, 0.8);
    }

    .glow-accent {
      box-shadow: 0 0 40px rgba(6, 182, 212, 0.15);
    }

    .pulse-dot {
      animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    .slide-in {
      animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .fade-in {
      animation: fadeIn 0.5s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .typing-indicator span {
      animation: blink 1.4s infinite both;
    }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes blink {
      0%, 100% { opacity: 0.2; }
      50% { opacity: 1; }
    }

    .scrollbar-thin::-webkit-scrollbar { width: 6px; }
    .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #374151; border-radius: 3px; }
    .scrollbar-thin::-webkit-scrollbar-thumb:hover { background: #4b5563; }

    .stat-card:hover { transform: translateY(-2px); }
    .insight-card:hover { border-color: rgba(6, 182, 212, 0.5); }

    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: #06b6d4;
      box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.1);
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full gradient-mesh text-vorenth-text overflow-auto">
  <div id="app" class="h-full w-full"><!-- Auth Screen -->
   <div id="auth-screen" class="h-full w-full flex items-center justify-center p-4">
    <div class="w-full max-w-md"><!-- Logo -->
     <div class="text-center mb-8 fade-in">
      <div class="inline-flex items-center gap-3 mb-4">
       <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center glow-accent">
        <svg class="w-7 h-7 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z" /> <path d="M2 17l10 5 10-5" /> <path d="M2 12l10 5 10-5" />
        </svg>
       </div>
       <h1 id="auth-logo-text" class="text-3xl font-bold text-white">Vorenth</h1>
      </div>
      <p id="auth-tagline" class="text-vorenth-muted">AI-Powered Global Intelligence Platform</p>
     </div><!-- Auth Card -->
     <div class="glass-card rounded-2xl p-8 glow-accent">
      <div id="auth-tabs" class="flex gap-2 mb-6 p-1 bg-vorenth-darker rounded-lg"><button onclick="showAuthTab('login')" id="login-tab" class="flex-1 py-2.5 px-4 rounded-md text-sm font-medium transition-all bg-vorenth-accent text-white">Sign In</button> <button onclick="showAuthTab('register')" id="register-tab" class="flex-1 py-2.5 px-4 rounded-md text-sm font-medium transition-all text-vorenth-muted hover:text-white">Register</button>
      </div><!-- Login Form -->
      <form id="login-form" class="space-y-4" onsubmit="handleLogin(event)">
       <div><label class="block text-sm font-medium text-vorenth-muted mb-2">Email</label> <input type="email" id="login-email" placeholder="you@company.com" required class="w-full px-4 py-3 bg-vorenth-darker border border-vorenth-border rounded-lg text-white placeholder-vorenth-muted transition-all">
       </div>
       <div><label class="block text-sm font-medium text-vorenth-muted mb-2">Password</label> <input type="password" id="login-password" placeholder="••••••••" required class="w-full px-4 py-3 bg-vorenth-darker border border-vorenth-border rounded-lg text-white placeholder-vorenth-muted transition-all">
       </div><button type="submit" id="login-btn" class="w-full py-3 px-4 bg-vorenth-accent hover:bg-vorenth-accentHover text-white font-medium rounded-lg transition-all flex items-center justify-center gap-2"> <span>Sign In</span> <i data-lucide="arrow-right" class="w-4 h-4"></i> </button>
      </form><!-- Register Form -->
      <form id="register-form" class="space-y-4 hidden" onsubmit="handleRegister(event)">
       <div><label class="block text-sm font-medium text-vorenth-muted mb-2">Full Name</label> <input type="text" id="register-name" placeholder="John Doe" required class="w-full px-4 py-3 bg-vorenth-darker border border-vorenth-border rounded-lg text-white placeholder-vorenth-muted transition-all">
       </div>
       <div><label class="block text-sm font-medium text-vorenth-muted mb-2">Email</label> <input type="email" id="register-email" placeholder="you@company.com" required class="w-full px-4 py-3 bg-vorenth-darker border border-vorenth-border rounded-lg text-white placeholder-vorenth-muted transition-all">
       </div>
       <div><label class="block text-sm font-medium text-vorenth-muted mb-2">Password</label> <input type="password" id="register-password" placeholder="••••••••" required minlength="8" class="w-full px-4 py-3 bg-vorenth-darker border border-vorenth-border rounded-lg text-white placeholder-vorenth-muted transition-all">
       </div><button type="submit" id="register-btn" class="w-full py-3 px-4 bg-vorenth-accent hover:bg-vorenth-accentHover text-white font-medium rounded-lg transition-all flex items-center justify-center gap-2"> <span>Create Account</span> <i data-lucide="user-plus" class="w-4 h-4"></i> </button>
      </form>
      <div id="auth-message" class="mt-4 text-center text-sm hidden"></div><!-- Subscription Plans -->
      <div class="mt-6 pt-6 border-t border-vorenth-border">
       <p class="text-center text-sm text-vorenth-muted mb-4">Choose your plan</p>
       <div class="grid grid-cols-2 gap-3"><button onclick="selectPlan('starter')" id="plan-starter" class="p-3 rounded-lg border-2 border-vorenth-accent bg-vorenth-accent/10 transition-all">
         <div class="text-sm font-semibold text-white">
          Starter
         </div>
         <div class="text-xs text-vorenth-muted">
          $29/month
         </div></button> <button onclick="selectPlan('pro')" id="plan-pro" class="p-3 rounded-lg border-2 border-vorenth-border hover:border-vorenth-accent/50 transition-all">
         <div class="text-sm font-semibold text-white">
          Pro
         </div>
         <div class="text-xs text-vorenth-muted">
          $99/month
         </div></button>
       </div>
      </div>
     </div>
     <p class="text-center text-xs text-vorenth-muted mt-6">By signing up, you agree to our Terms of Service and Privacy Policy</p>
    </div>
   </div><!-- Main Dashboard -->
   <div id="dashboard-screen" class="h-full w-full hidden"><!-- Sidebar -->
    <aside id="sidebar" class="fixed left-0 top-0 h-full w-64 bg-vorenth-darker border-r border-vorenth-border z-40 transform transition-transform lg:translate-x-0 -translate-x-full">
     <div class="h-full flex flex-col"><!-- Logo -->
      <div class="p-5 border-b border-vorenth-border">
       <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center">
         <svg class="w-6 h-6 text-white" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z" /> <path d="M2 17l10 5 10-5" /> <path d="M2 12l10 5 10-5" />
         </svg>
        </div><span id="sidebar-logo" class="text-xl font-bold text-white">Vorenth</span>
       </div>
      </div><!-- Navigation -->
      <nav class="flex-1 p-4 space-y-1 overflow-y-auto scrollbar-thin"><button onclick="navigateTo('overview')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all bg-vorenth-accent/10 text-vorenth-accent" data-nav="overview"> <i data-lucide="layout-dashboard" class="w-5 h-5"></i> <span class="font-medium">Overview</span> </button> <button onclick="navigateTo('insights')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="insights"> <i data-lucide="brain" class="w-5 h-5"></i> <span class="font-medium">AI Insights</span> </button> <button onclick="navigateTo('narratives')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="narratives"> <i data-lucide="trending-up" class="w-5 h-5"></i> <span class="font-medium">Narratives</span> </button> <button onclick="navigateTo('markets')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="markets"> <i data-lucide="bar-chart-3" class="w-5 h-5"></i> <span class="font-medium">Markets</span> </button> <button onclick="navigateTo('search')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="search"> <i data-lucide="search" class="w-5 h-5"></i> <span class="font-medium">Deep Search</span> </button> <button onclick="navigateTo('saved')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="saved"> <i data-lucide="bookmark" class="w-5 h-5"></i> <span class="font-medium">Saved</span> </button>
       <div class="pt-4 mt-4 border-t border-vorenth-border">
        <p class="px-4 text-xs font-semibold text-vorenth-muted uppercase tracking-wider mb-2">Settings</p><button onclick="navigateTo('account')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="account"> <i data-lucide="user" class="w-5 h-5"></i> <span class="font-medium">Account</span> </button> <button onclick="navigateTo('billing')" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-all text-vorenth-muted hover:text-white hover:bg-vorenth-card" data-nav="billing"> <i data-lucide="credit-card" class="w-5 h-5"></i> <span class="font-medium">Billing</span> </button>
       </div>
      </nav><!-- User Info -->
      <div class="p-4 border-t border-vorenth-border">
       <div class="flex items-center gap-3">
        <div id="user-avatar" class="w-10 h-10 rounded-full bg-gradient-to-br from-cyan-500 to-purple-600 flex items-center justify-center text-white font-semibold">
         JD
        </div>
        <div class="flex-1 min-w-0">
         <p id="user-name" class="text-sm font-medium text-white truncate">John Doe</p>
         <p id="user-plan" class="text-xs text-vorenth-muted">Starter Plan</p>
        </div><button onclick="handleLogout()" class="p-2 text-vorenth-muted hover:text-white transition-colors"> <i data-lucide="log-out" class="w-5 h-5"></i> </button>
       </div>
      </div>
     </div>
    </aside><!-- Sidebar Overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-30 lg:hidden hidden" onclick="toggleSidebar()"></div><!-- Main Content -->
    <main class="lg:ml-64 h-full overflow-auto"><!-- Top Bar -->
     <header class="sticky top-0 z-20 bg-vorenth-dark/80 backdrop-blur-xl border-b border-vorenth-border">
      <div class="flex items-center justify-between px-4 lg:px-6 py-4">
       <div class="flex items-center gap-4"><button onclick="toggleSidebar()" class="lg:hidden p-2 text-vorenth-muted hover:text-white"> <i data-lucide="menu" class="w-6 h-6"></i> </button>
        <div>
         <h1 id="page-title" class="text-xl font-bold text-white">Overview</h1>
         <p id="page-subtitle" class="text-sm text-vorenth-muted">Real-time global intelligence</p>
        </div>
       </div>
       <div class="flex items-center gap-3"><!-- Global Search -->
        <div class="hidden md:block relative"><input type="text" id="global-search" placeholder="Search topics, regions..." class="w-64 pl-10 pr-4 py-2 bg-vorenth-card border border-vorenth-border rounded-lg text-sm text-white placeholder-vorenth-muted transition-all focus:w-80" onkeypress="handleGlobalSearch(event)"> <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-vorenth-muted"></i>
        </div><!-- Notifications --> <button class="relative p-2 text-vorenth-muted hover:text-white transition-colors"> <i data-lucide="bell" class="w-5 h-5"></i> <span class="absolute top-1 right-1 w-2 h-2 bg-vorenth-accent rounded-full pulse-dot"></span> </button> <!-- Refresh --> <button onclick="refreshData()" id="refresh-btn" class="p-2 text-vorenth-muted hover:text-white transition-colors"> <i data-lucide="refresh-cw" class="w-5 h-5"></i> </button>
       </div>
      </div>
     </header><!-- Page Content -->
     <div id="page-content" class="p-4 lg:p-6"><!-- Overview Page -->
      <div id="page-overview" class="page-section space-y-6"><!-- Welcome Banner -->
       <div class="glass-card rounded-2xl p-6 glow-accent">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
         <div>
          <h2 id="welcome-text" class="text-2xl font-bold text-white mb-2">Welcome back to Vorenth</h2>
          <p class="text-vorenth-muted">Your global intelligence briefing is ready. Here's what's happening around the world.</p>
         </div>
         <div class="flex items-center gap-2 text-sm"><span class="w-2 h-2 bg-vorenth-success rounded-full pulse-dot"></span> <span class="text-vorenth-muted">Live data feed active</span>
         </div>
        </div>
       </div><!-- Stats Grid -->
       <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="stat-card glass-card rounded-xl p-5 transition-all cursor-pointer" onclick="navigateTo('narratives')">
         <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center"><i data-lucide="trending-up" class="w-5 h-5 text-cyan-400"></i>
          </div><span class="text-xs text-vorenth-success font-medium">+12%</span>
         </div>
         <p id="stat-narratives" class="text-2xl font-bold text-white">47</p>
         <p class="text-sm text-vorenth-muted">Active Narratives</p>
        </div>
        <div class="stat-card glass-card rounded-xl p-5 transition-all cursor-pointer" onclick="navigateTo('insights')">
         <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-lg bg-purple-500/20 flex items-center justify-center"><i data-lucide="brain" class="w-5 h-5 text-purple-400"></i>
          </div><span class="text-xs text-vorenth-success font-medium">+8%</span>
         </div>
         <p id="stat-insights" class="text-2xl font-bold text-white">156</p>
         <p class="text-sm text-vorenth-muted">AI Insights Today</p>
        </div>
        <div class="stat-card glass-card rounded-xl p-5 transition-all cursor-pointer" onclick="navigateTo('markets')">
         <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-lg bg-green-500/20 flex items-center justify-center"><i data-lucide="globe" class="w-5 h-5 text-green-400"></i>
          </div><span class="text-xs text-vorenth-warning font-medium">±3%</span>
         </div>
         <p id="stat-regions" class="text-2xl font-bold text-white">28</p>
         <p class="text-sm text-vorenth-muted">Regions Tracked</p>
        </div>
        <div class="stat-card glass-card rounded-xl p-5 transition-all cursor-pointer" onclick="navigateTo('saved')">
         <div class="flex items-center justify-between mb-3">
          <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center"><i data-lucide="bookmark" class="w-5 h-5 text-amber-400"></i>
          </div>
         </div>
         <p id="stat-saved" class="text-2xl font-bold text-white">0</p>
         <p class="text-sm text-vorenth-muted">Saved Items</p>
        </div>
       </div><!-- Main Grid -->
       <div class="grid lg:grid-cols-3 gap-6"><!-- Trending Narratives -->
        <div class="lg:col-span-2 glass-card rounded-2xl p-6">
         <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-white">Trending Narratives</h3><button onclick="navigateTo('narratives')" class="text-sm text-vorenth-accent hover:underline">View all</button>
         </div>
         <div id="trending-narratives" class="space-y-4"><!-- Will be populated dynamically -->
         </div>
        </div><!-- AI Intelligence Brief -->
        <div class="glass-card rounded-2xl p-6">
         <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-cyan-500 to-purple-600 flex items-center justify-center"><i data-lucide="sparkles" class="w-5 h-5 text-white"></i>
          </div>
          <div>
           <h3 class="text-lg font-semibold text-white">AI Brief</h3>
           <p class="text-xs text-vorenth-muted">Updated 5 min ago</p>
          </div>
         </div>
         <div id="ai-brief" class="space-y-4 text-sm text-vorenth-text leading-relaxed">
          <p>Loading intelligence brief...</p>
         </div>
        </div>
       </div><!-- Recent Insights -->
       <div class="glass-card rounded-2xl p-6">
        <div class="flex items-center justify-between mb-6">
         <h3 class="text-lg font-semibold text-white">Recent Intelligence</h3><button onclick="navigateTo('insights')" class="text-sm text-vorenth-accent hover:underline">View all</button>
        </div>
        <div id="recent-insights" class="grid md:grid-cols-2 lg:grid-cols-3 gap-4"><!-- Will be populated dynamically -->
        </div>
       </div>
      </div><!-- AI Insights Page -->
      <div id="page-insights" class="page-section hidden space-y-6">
       <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
         <h2 class="text-xl font-bold text-white">AI-Generated Insights</h2>
         <p class="text-sm text-vorenth-muted">Automated analysis of global events and trends</p>
        </div>
        <div class="flex items-center gap-3"><select id="insight-filter" class="px-4 py-2 bg-vorenth-card border border-vorenth-border rounded-lg text-sm text-white" onchange="filterInsights()"> <option value="all">All Categories</option> <option value="geopolitical">Geopolitical</option> <option value="economic">Economic</option> <option value="technology">Technology</option> <option value="security">Security</option> </select> <button onclick="generateNewInsight()" class="px-4 py-2 bg-vorenth-accent hover:bg-vorenth-accentHover text-white rounded-lg text-sm font-medium transition-all flex items-center gap-2"> <i data-lucide="sparkles" class="w-4 h-4"></i> Generate New </button>
        </div>
       </div>
       <div id="insights-list" class="grid md:grid-cols-2 gap-4"><!-- Will be populated dynamically -->
       </div>
      </div><!-- Narratives Page -->
      <div id="page-narratives" class="page-section hidden space-y-6">
       <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
         <h2 class="text-xl font-bold text-white">Global Narratives</h2>
         <p class="text-sm text-vorenth-muted">Emerging stories and developing trends</p>
        </div>
        <div class="flex items-center gap-3"><select id="narrative-region" class="px-4 py-2 bg-vorenth-card border border-vorenth-border rounded-lg text-sm text-white" onchange="filterNarratives()"> <option value="all">All Regions</option> <option value="north-america">North America</option> <option value="europe">Europe</option> <option value="asia-pacific">Asia-Pacific</option> <option value="middle-east">Middle East</option> <option value="africa">Africa</option> <option value="latin-america">Latin America</option> </select>
        </div>
       </div>
       <div id="narratives-list" class="space-y-4"><!-- Will be populated dynamically -->
       </div>
      </div><!-- Markets Page -->
      <div id="page-markets" class="page-section hidden space-y-6">
       <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
         <h2 class="text-xl font-bold text-white">Market Intelligence</h2>
         <p class="text-sm text-vorenth-muted">Financial data and market analysis</p>
        </div>
        <div class="flex items-center gap-2 text-sm"><span class="w-2 h-2 bg-vorenth-success rounded-full pulse-dot"></span> <span class="text-vorenth-muted">Markets open</span>
        </div>
       </div><!-- Market Overview -->
       <div class="grid md:grid-cols-4 gap-4">
        <div class="glass-card rounded-xl p-5">
         <div class="flex items-center justify-between mb-2"><span class="text-sm text-vorenth-muted">S&amp;P 500</span> <span class="text-xs text-vorenth-success">+0.47%</span>
         </div>
         <p class="text-xl font-bold text-white mono">5,234.18</p>
        </div>
        <div class="glass-card rounded-xl p-5">
         <div class="flex items-center justify-between mb-2"><span class="text-sm text-vorenth-muted">NASDAQ</span> <span class="text-xs text-vorenth-success">+0.82%</span>
         </div>
