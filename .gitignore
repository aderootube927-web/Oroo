   </div><!-- Toast Container -->
   <div id="toast-container" class="fixed bottom-4 right-4 z-50 space-y-2"></div>
  </div>
  <script>
    // ==================== State Management ====================
    let currentUser = null;
    let selectedPlan = 'starter';
    let currentPage = 'overview';
    let savedItems = [];
    let allInsights = [];
    let currentSearchQuery = '';
    let currentSearchResult = null;

    // Default configuration
    const defaultConfig = {
      platform_name: 'Vorenth',
      tagline: 'AI-Powered Global Intelligence Platform',
      welcome_message: 'Welcome back to Vorenth',
      background_color: '#0a0f1a',
      surface_color: '#111827',
      text_color: '#e5e7eb',
      accent_color: '#06b6d4',
      secondary_color: '#6b7280',
      font_family: 'Space Grotesk',
      font_size: 16
    };

    // ==================== Sample Data ====================
    const sampleNarratives = [
      {
        id: 'n1',
        title: 'US-China Tech Decoupling Accelerates',
        category: 'geopolitical',
        region: 'asia-pacific',
        sentiment: 'negative',
        relevance: 95,
        summary: 'New semiconductor export restrictions signal deepening technological divide between major powers.',
        timestamp: new Date().toISOString()
      },
      {
        id: 'n2',
        title: 'European Energy Transition Gains Momentum',
        category: 'economic',
        region: 'europe',
        sentiment: 'positive',
        relevance: 88,
        summary: 'Major investments in renewable infrastructure reshape continental energy landscape.',
        timestamp: new Date().toISOString()
      },
      {
        id: 'n3',
        title: 'AI Regulation Frameworks Emerge Globally',
        category: 'technology',
        region: 'north-america',
        sentiment: 'neutral',
        relevance: 92,
        summary: 'Multiple jurisdictions advance comprehensive AI governance policies.',
        timestamp: new Date().toISOString()
      },
      {
        id: 'n4',
        title: 'Middle East Diplomatic Realignment',
        category: 'geopolitical',
        region: 'middle-east',
        sentiment: 'positive',
        relevance: 85,
        summary: 'Regional powers pursue normalization agreements amid shifting alliances.',
        timestamp: new Date().toISOString()
      },
      {
        id: 'n5',
        title: 'Global Supply Chain Restructuring',
        category: 'economic',
        region: 'asia-pacific',
        sentiment: 'neutral',
        relevance: 90,
        summary: 'Corporations diversify manufacturing bases in response to geopolitical risks.',
        timestamp: new Date().toISOString()
      }
    ];

    const sampleInsights = [
      {
        id: 'i1',
        type: 'insight',
        title: 'Semiconductor Industry Analysis',
        content: 'The global semiconductor industry faces unprecedented restructuring as major economies pursue strategic autonomy. TSMC\'s Arizona expansion and Intel\'s European investments signal a fundamental shift in chip manufacturing geography.',
        category: 'technology',
        sentiment: 'neutral',
        relevance: 94,
        source: 'AI Analysis',
        region: 'north-america',
        timestamp: new Date().toISOString(),
        saved: false
      },
      {
        id: 'i2',
        type: 'insight',
        title: 'Currency Market Volatility Outlook',
        content: 'Divergent central bank policies create opportunities and risks across currency pairs. The Fed\'s rate trajectory versus ECB and BOJ approaches will drive major FX movements through Q2.',
        category: 'economic',
        sentiment: 'neutral',
        relevance: 87,
        source: 'AI Analysis',
        region: 'europe',
        timestamp: new Date().toISOString(),
        saved: false
      },
      {
        id: 'i3',
        type: 'insight',
        title: 'Cybersecurity Threat Assessment',
        content: 'State-sponsored cyber activities targeting critical infrastructure have increased 47% YoY. Financial services and energy sectors remain primary targets.',
        category: 'security',
        sentiment: 'negative',
        relevance: 91,
        source: 'AI Analysis',
        region: 'north-america',
        timestamp: new Date().toISOString(),
        saved: false
      },
      {
        id: 'i4',
        type: 'insight',
        title: 'Emerging Markets Capital Flows',
        content: 'Strong dollar dynamics continue pressuring EM currencies and bonds. Selective opportunities exist in markets with solid fundamentals and improving current accounts.',
        category: 'economic',
        sentiment: 'neutral',
        relevance: 83,
        source: 'AI Analysis',
        region: 'latin-america',
        timestamp: new Date().toISOString(),
        saved: false
      }
    ];

    const aiBriefContent = `
      <p><strong>Key Developments:</strong></p>
      <p>Global markets show mixed signals as investors weigh inflation data against corporate earnings. Technology sector leads gains while energy faces headwinds from demand concerns.</p>
      <p class="mt-3"><strong>Watch List:</strong></p>
      <ul class="list-disc list-inside text-vorenth-muted space-y-1 mt-2">
        <li>Fed policy meeting outcomes</li>
        <li>China economic data release</li>
        <li>European energy prices</li>
        <li>AI sector developments</li>
      </ul>
      <p class="mt-3"><strong>Risk Assessment:</strong> <span class="text-vorenth-warning">Moderate</span></p>
    `;

    const marketAnalysisContent = `
      <p><strong>Market Overview:</strong></p>
      <p>US equities continue their upward trajectory supported by strong tech earnings and easing inflation concerns. The S&P 500 approaches all-time highs as breadth improves across sectors.</p>
      <p class="mt-4"><strong>Key Themes:</strong></p>
      <ul class="list-disc list-inside space-y-2 mt-2">
        <li><strong>AI Investment Surge:</strong> Capital expenditure on AI infrastructure drives tech valuations higher. Major cloud providers report record data center demand.</li>
        <li><strong>Rate Expectations:</strong> Markets price in potential rate cuts in H2, supporting risk assets and compressing credit spreads.</li>
        <li><strong>Geopolitical Premium:</strong> Oil markets incorporate modest risk premium amid Middle East tensions, though ample supply caps upside.</li>
      </ul>
      <p class="mt-4"><strong>Outlook:</strong> Constructive near-term with attention on earnings sustainability and policy evolution.</p>
    `;

    // ==================== SDK Initialization ====================
    async function initializeApp() {
      // Initialize Element SDK
      if (window.elementSdk) {
        window.elementSdk.init({
          defaultConfig,
          onConfigChange: async (config) => {
            applyConfig(config);
          },
          mapToCapabilities: (config) => ({
            recolorables: [
              {
                get: () => config.background_color || defaultConfig.background_color,
                set: (value) => window.elementSdk.setConfig({ background_color: value })
              },
              {
                get: () => config.surface_color || defaultConfig.surface_color,
                set: (value) => window.elementSdk.setConfig({ surface_color: value })
              },
              {
                get: () => config.text_color || defaultConfig.text_color,
                set: (value) => window.elementSdk.setConfig({ text_color: value })
              },
              {
                get: () => config.accent_color || defaultConfig.accent_color,
                set: (value) => window.elementSdk.setConfig({ accent_color: value })
              },
              {
                get: () => config.secondary_color || defaultConfig.secondary_color,
                set: (value) => window.elementSdk.setConfig({ secondary_color: value })
              }
            ],
            borderables: [],
            fontEditable: {
              get: () => config.font_family || defaultConfig.font_family,
              set: (value) => window.elementSdk.setConfig({ font_family: value })
            },
            fontSizeable: {
              get: () => config.font_size || defaultConfig.font_size,
              set: (value) => window.elementSdk.setConfig({ font_size: value })
            }
          }),
          mapToEditPanelValues: (config) => new Map([
            ['platform_name', config.platform_name || defaultConfig.platform_name],
            ['tagline', config.tagline || defaultConfig.tagline],
            ['welcome_message', config.welcome_message || defaultConfig.welcome_message]
          ])
        });
      }

      // Initialize Data SDK
      if (window.dataSdk) {
        const result = await window.dataSdk.init({
          onDataChanged: (data) => {
            savedItems = data.filter(item => item.saved);
            allInsights = data;
            updateSavedCount();
            renderSavedItems();
          }
        });

        if (!result.isOk) {
          console.error('Failed to initialize Data SDK');
        }
      }

      // Initialize UI
      lucide.createIcons();
      renderDashboard();
    }

    function applyConfig(config) {
      const cfg = { ...defaultConfig, ...config };

      // Update platform name
      const authLogo = document.getElementById('auth-logo-text');
      const sidebarLogo = document.getElementById('sidebar-logo');
      if (authLogo) authLogo.textContent = cfg.platform_name;
      if (sidebarLogo) sidebarLogo.textContent = cfg.platform_name;

      // Update tagline
      const authTagline = document.getElementById('auth-tagline');
      if (authTagline) authTagline.textContent = cfg.tagline;

      // Update welcome message
      const welcomeText = document.getElementById('welcome-text');
      if (welcomeText) welcomeText.textContent = cfg.welcome_message;

      // Apply colors
      document.documentElement.style.setProperty('--bg-color', cfg.background_color);
      document.documentElement.style.setProperty('--surface-color', cfg.surface_color);
      document.documentElement.style.setProperty('--text-color', cfg.text_color);
      document.documentElement.style.setProperty('--accent-color', cfg.accent_color);
      document.documentElement.style.setProperty('--secondary-color', cfg.secondary_color);

      // Apply font
      document.body.style.fontFamily = `${cfg.font_family}, Space Grotesk, sans-serif`;

      // Apply font size
      document.documentElement.style.fontSize = `${cfg.font_size}px`;
    }

    // ==================== Authentication ====================
    function showAuthTab(tab) {
      const loginForm = document.getElementById('login-form');
      const registerForm = document.getElementById('register-form');
      const loginTab = document.getElementById('login-tab');
      const registerTab = document.getElementById('register-tab');

      if (tab === 'login') {
        loginForm.classList.remove('hidden');
        registerForm.classList.add('hidden');
        loginTab.classList.add('bg-vorenth-accent', 'text-white');
        loginTab.classList.remove('text-vorenth-muted');
        registerTab.classList.remove('bg-vorenth-accent', 'text-white');
        registerTab.classList.add('text-vorenth-muted');
      } else {
        loginForm.classList.add('hidden');
        registerForm.classList.remove('hidden');
        registerTab.classList.add('bg-vorenth-accent', 'text-white');
        registerTab.classList.remove('text-vorenth-muted');
        loginTab.classList.remove('bg-vorenth-accent', 'text-white');
        loginTab.classList.add('text-vorenth-muted');
      }

      hideAuthMessage();
    }

    function selectPlan(plan) {
      selectedPlan = plan;
      const starterBtn = document.getElementById('plan-starter');
      const proBtn = document.getElementById('plan-pro');

      if (plan === 'starter') {
        starterBtn.classList.add('border-vorenth-accent', 'bg-vorenth-accent/10');
        starterBtn.classList.remove('border-vorenth-border');
        proBtn.classList.remove('border-vorenth-accent', 'bg-vorenth-accent/10');
        proBtn.classList.add('border-vorenth-border');
      } else {
        proBtn.classList.add('border-vorenth-accent', 'bg-vorenth-accent/10');
        proBtn.classList.remove('border-vorenth-border');
        starterBtn.classList.remove('border-vorenth-accent', 'bg-vorenth-accent/10');
        starterBtn.classList.add('border-vorenth-border');
      }
    }

    function handleLogin(event) {
      event.preventDefault();
      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;

      // Simulate login
      if (email && password) {
        currentUser = {
          name: 'John Doe',
          email: email,
          plan: selectedPlan
        };
        showDashboard();
        showToast('Welcome back!', 'success');
      } else {
        showAuthMessage('Please enter valid credentials', 'error');
      }
    }

    function handleRegister(event) {
      event.preventDefault();
      const name = document.getElementById('register-name').value;
      const email = document.getElementById('register-email').value;
      const password = document.getElementById('register-password').value;

      // Simulate registration
      if (name && email && password.length >= 8) {
        currentUser = {
          name: name,
          email: email,
          plan: selectedPlan
        };
        showDashboard();
        showToast('Account created successfully!', 'success');
      } else {
        showAuthMessage('Please fill all fields correctly', 'error');
      }
    }

    function handleLogout() {
      currentUser = null;
      document.getElementById('auth-screen').classList.remove('hidden');
      document.getElementById('dashboard-screen').classList.add('hidden');
      showToast('Logged out successfully', 'success');
    }

    function showAuthMessage(message, type) {
      const msgEl = document.getElementById('auth-message');
      msgEl.textContent = message;
      msgEl.classList.remove('hidden', 'text-vorenth-success', 'text-vorenth-danger');
      msgEl.classList.add(type === 'error' ? 'text-vorenth-danger' : 'text-vorenth-success');
    }

    function hideAuthMessage() {
      document.getElementById('auth-message').classList.add('hidden');
    }

    // ==================== Dashboard ====================
    function showDashboard() {
      document.getElementById('auth-screen').classList.add('hidden');
      document.getElementById('dashboard-screen').classList.remove('hidden');

      // Update user info
      if (currentUser) {
        const initials = currentUser.name.split(' ').map(n => n[0]).join('');
        document.getElementById('user-avatar').textContent = initials;
        document.getElementById('user-name').textContent = currentUser.name;
        document.getElementById('user-plan').textContent = `${currentUser.plan.charAt(0).toUpperCase() + currentUser.plan.slice(1)} Plan`;
        document.getElementById('account-name').value = currentUser.name;
        document.getElementById('account-email').value = currentUser.email;
        document.getElementById('billing-plan').textContent = currentUser.plan === 'starter' ? 'Starter Plan - $29/month' : 'Pro Plan - $99/month';
      }

      lucide.createIcons();
      renderDashboard();
    }

    function renderDashboard() {
      renderTrendingNarratives();
      renderAIBrief();
      renderRecentInsights();
      renderInsightsList();
      renderNarrativesList();
      renderMarketAnalysis();
      updateSavedCount();
    }

    function renderTrendingNarratives() {
      const container = document.getElementById('trending-narratives');
      if (!container) return;

      container.innerHTML = sampleNarratives.slice(0, 4).map((narrative, index) => `
        <div class="insight-card flex items-start gap-4 p-4 bg-vorenth-darker rounded-xl border border-vorenth-border transition-all cursor-pointer slide-in" style="animation-delay: ${index * 0.1}s" onclick="viewNarrative('${narrative.id}')">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg ${getSentimentBg(narrative.sentiment)} flex items-center justify-center">
            <i data-lucide="${getCategoryIcon(narrative.category)}" class="w-5 h-5 ${getSentimentColor(narrative.sentiment)}"></i>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="px-2 py-0.5 bg-vorenth-card rounded text-xs text-vorenth-muted capitalize">${narrative.region.replace('-', ' ')}</span>
              <span class="text-xs text-vorenth-muted">${narrative.relevance}% relevance</span>
            </div>
            <h4 class="text-sm font-medium text-white mb-1 truncate">${narrative.title}</h4>
            <p class="text-xs text-vorenth-muted line-clamp-2">${narrative.summary}</p>
          </div>
          <button onclick="event.stopPropagation(); toggleSaveNarrative('${narrative.id}')" class="p-2 text-vorenth-muted hover:text-vorenth-accent transition-colors">
            <i data-lucide="bookmark" class="w-4 h-4"></i>
          </button>
        </div>
      `).join('');

      lucide.createIcons();
    }

    function renderAIBrief() {
      const container = document.getElementById('ai-brief');
      if (container) {
        container.innerHTML = aiBriefContent;
      }
    }

    function renderRecentInsights() {
      const container = document.getElementById('recent-insights');
      if (!container) return;

      container.innerHTML = sampleInsights.slice(0, 3).map((insight, index) => `
        <div class="insight-card glass-card rounded-xl p-5 border border-vorenth-border transition-all cursor-pointer slide-in" style="animation-delay: ${index * 0.1}s" onclick="viewInsight('${insight.id}')">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2 py-1 ${getCategoryBadgeBg(insight.category)} rounded text-xs font-medium capitalize">${insight.category}</span>
            <span class="text-xs text-vorenth-muted">${insight.relevance}%</span>
          </div>
          <h4 class="text-sm font-semibold text-white mb-2">${insight.title}</h4>
          <p class="text-xs text-vorenth-muted line-clamp-3">${insight.content}</p>
          <div class="flex items-center justify-between mt-4 pt-3 border-t border-vorenth-border">
            <span class="text-xs text-vorenth-muted">${insight.source}</span>
            <button onclick="event.stopPropagation(); toggleSaveInsight('${insight.id}')" class="text-vorenth-muted hover:text-vorenth-accent transition-colors">
              <i data-lucide="bookmark" class="w-4 h-4"></i>
            </button>
          </div>
        </div>
      `).join('');

      lucide.createIcons();
    }

    function renderInsightsList() {
      const container = document.getElementById('insights-list');
      if (!container) return;

      container.innerHTML = sampleInsights.map((insight, index) => `
        <div class="insight-card glass-card rounded-xl p-6 border border-vorenth-border transition-all slide-in" style="animation-delay: ${index * 0.05}s">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-2">
              <span class="px-2 py-1 ${getCategoryBadgeBg(insight.category)} rounded text-xs font-medium capitalize">${insight.category}</span>
              <span class="px-2 py-1 ${getSentimentBadgeBg(insight.sentiment)} rounded text-xs font-medium capitalize">${insight.sentiment}</span>
            </div>
            <span class="text-xs text-vorenth-muted mono">${insight.relevance}% relevance</span>
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">${insight.title}</h3>
          <p class="text-sm text-vorenth-text leading-relaxed mb-4">${insight.content}</p>
          <div class="flex items-center justify-between pt-4 border-t border-vorenth-border">
            <div class="flex items-center gap-4 text-xs text-vorenth-muted">
              <span>${insight.source}</span>
              <span>•</span>
              <span class="capitalize">${insight.region.replace('-', ' ')}</span>
            </div>
            <button onclick="toggleSaveInsight('${insight.id}')" class="flex items-center gap-2 text-sm text-vorenth-muted hover:text-vorenth-accent transition-colors">
              <i data-lucide="bookmark" class="w-4 h-4"></i>
              Save
            </button>
          </div>
        </div>
      `).join('');

      lucide.createIcons();
    }

    function renderNarrativesList() {
      const container = document.getElementById('narratives-list');
      if (!container) return;

      container.innerHTML = sampleNarratives.map((narrative, index) => `
        <div class="insight-card glass-card rounded-xl p-6 border border-vorenth-border transition-all slide-in" style="animation-delay: ${index * 0.05}s">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl ${getSentimentBg(narrative.sentiment)} flex items-center justify-center">
              <i data-lucide="${getCategoryIcon(narrative.category)}" class="w-6 h-6 ${getSentimentColor(narrative.sentiment)}"></i>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-1 bg-vorenth-card rounded text-xs text-vorenth-muted capitalize">${narrative.region.replace('-', ' ')}</span>
                <span class="px-2 py-1 ${getCategoryBadgeBg(narrative.category)} rounded text-xs font-medium capitalize">${narrative.category}</span>
                <span class="ml-auto text-xs text-vorenth-muted mono">${narrative.relevance}%</span>
              </div>
              <h3 class="text-lg font-semibold text-white mb-2">${narrative.title}</h3>
              <p class="text-sm text-vorenth-muted">${narrative.summary}</p>
              <div class="flex items-center gap-4 mt-4">
                <button onclick="viewNarrative('${narrative.id}')" class="text-sm text-vorenth-accent hover:underline">Read analysis →</button>
                <button onclick="toggleSaveNarrative('${narrative.id}')" class="text-sm text-vorenth-muted hover:text-vorenth-accent transition-colors flex items-center gap-1">
                  <i data-lucide="bookmark" class="w-4 h-4"></i>
                  Save
                </button>
              </div>
            </div>
          </div>
        </div>
      `).join('');

      lucide.createIcons();
    }

    function renderMarketAnalysis() {
      const container = document.getElementById('market-analysis');
      if (container) {
        container.innerHTML = marketAnalysisContent;
      }
    }

    function renderSavedItems() {
      const container = document.getElementById('saved-list');
      if (!container) return;

      if (savedItems.length === 0) {
        container.innerHTML = `
          <div class="glass-card rounded-xl p-8 text-center">
            <div class="w-16 h-16 rounded-full bg-vorenth-card mx-auto mb-4 flex items-center justify-center">
              <i data-lucide="bookmark" class="w-8 h-8 text-vorenth-muted"></i>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">No saved items yet</h3>
            <p class="text-sm text-vorenth-muted">Bookmark insights and search results to save them here</p>
          </div>
        `;
      } else {
        container.innerHTML = savedItems.map((item, index) => `
          <div class="insight-card glass-card rounded-xl p-5 border border-vorenth-border transition-all slide-in" style="animation-delay: ${index * 0.05}s">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-1 ${getCategoryBadgeBg(item.category || 'general')} rounded text-xs font-medium capitalize">${item.category || 'Search Result'}</span>
                </div>
                <h4 class="text-sm font-semibold text-white mb-2">${item.title}</h4>
                <p class="text-xs text-vorenth-muted line-clamp-3">${item.content}</p>
              </div>
              <button onclick="removeSavedItem('${item.__backendId}')" class="p-2 text-vorenth-muted hover:text-vorenth-danger transition-colors">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
              </button>
            </div>
          </div>
        `).join('');
      }

      lucide.createIcons();
    }

    function updateSavedCount() {
      const statEl = document.getElementById('stat-saved');
      if (statEl) {
        statEl.textContent = savedItems.length;
      }
    }

    // ==================== Navigation ====================
    function navigateTo(page) {
      currentPage = page;

      // Update nav items
      document.querySelectorAll('.nav-item').forEach(item => {
        const navPage = item.dataset.nav;
        if (navPage === page) {
          item.classList.add('bg-vorenth-accent/10', 'text-vorenth-accent');
          item.classList.remove('text-vorenth-muted');
        } else {
          item.classList.remove('bg-vorenth-accent/10', 'text-vorenth-accent');
          item.classList.add('text-vorenth-muted');
        }
      });

      // Show/hide page sections
      document.querySelectorAll('.page-section').forEach(section => {
        section.classList.add('hidden');
      });
      const targetPage = document.getElementById(`page-${page}`);
      if (targetPage) {
        targetPage.classList.remove('hidden');
      }

      // Update page title
      const titles = {
        overview: ['Overview', 'Real-time global intelligence'],
        insights: ['AI Insights', 'Automated analysis of global events'],
        narratives: ['Global Narratives', 'Emerging stories and trends'],
        markets: ['Market Intelligence', 'Financial data and analysis'],
        search: ['Deep Search', 'AI-powered research assistant'],
        saved: ['Saved Items', 'Your bookmarked content'],
        account: ['Account Settings', 'Manage your profile'],
        billing: ['Billing', 'Subscription and payments']
      };

      const [title, subtitle] = titles[page] || ['Page', ''];
      document.getElementById('page-title').textContent = title;
      document.getElementById('page-subtitle').textContent = subtitle;

      // Close mobile sidebar
      if (window.innerWidth < 1024) {
        closeSidebar();
      }

      lucide.createIcons();
    }

    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');

      sidebar.classList.toggle('-translate-x-full');
      overlay.classList.toggle('hidden');
    }

    function closeSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');

      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
    }

    // ==================== Search ====================
    function handleGlobalSearch(event) {
      if (event.key === 'Enter') {
        const query = event.target.value.trim();
        if (query) {
          navigateTo('search');
          document.getElementById('deep-search-input').value = query;
          executeDeepSearch();
        }
      }
    }

    function handleSearchKeydown(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        executeDeepSearch();
      }
    }

    function quickSearch(query) {
      document.getElementById('deep-search-input').value = query;
      executeDeepSearch();
    }

    async function executeDeepSearch() {
      const input = document.getElementById('deep-search-input');
      const query = input.value.trim();

      if (!query) return;

      currentSearchQuery = query;

      // Show loading
      document.getElementById('search-loading').classList.remove('hidden');
      document.getElementById('search-results').classList.add('hidden');

      // Simulate AI analysis
      await new Promise(resolve => setTimeout(resolve, 2000));

      // Generate result
      const result = generateSearchResult(query);
      currentSearchResult = result;

      // Display result
      document.getElementById('search-loading').classList.add('hidden');
      document.getElementById('search-results').classList.remove('hidden');
      document.getElementById('search-query-display').textContent = `Query: "${query}"`;
      document.getElementById('search-result-content').innerHTML = result;

      lucide.createIcons();
    }

    function generateSearchResult(query) {
      const templates = {
        'china': `
          <p><strong>Analysis: ${query}</strong></p>
          <p class="mt-3">Current geopolitical dynamics involving China show significant developments across multiple domains:</p>
          <ul class="list-disc list-inside mt-3 space-y-2 text-vorenth-muted">
            <li><strong>Economic Policy:</strong> Recent monetary easing measures signal concerns about domestic growth trajectory</li>
            <li><strong>Trade Relations:</strong> Ongoing tensions with Western economies continue to reshape supply chains</li>
            <li><strong>Regional Influence:</strong> Diplomatic initiatives in Southeast Asia and Pacific nations intensify</li>
          </ul>
          <p class="mt-4"><strong>Risk Assessment:</strong> <span class="text-vorenth-warning">Elevated</span></p>
          <p class="mt-2 text-vorenth-muted text-xs">Based on analysis of 1,247 sources • Updated ${new Date().toLocaleString()}</p>
        `,
        'ai': `
          <p><strong>Analysis: ${query}</strong></p>
          <p class="mt-3">The global AI regulatory landscape is evolving rapidly:</p>
          <ul class="list-disc list-inside mt-3 space-y-2 text-vorenth-muted">
            <li><strong>EU AI Act:</strong> Comprehensive framework sets global precedent for risk-based regulation</li>
            <li><strong>US Approach:</strong> Executive orders and sector-specific guidance shape policy direction</li>
            <li><strong>Industry Response:</strong> Major tech companies establish self-regulatory frameworks</li>
          </ul>
          <p class="mt-4"><strong>Market Impact:</strong> <span class="text-vorenth-success">Positive for compliance-ready firms</span></p>
          <p class="mt-2 text-vorenth-muted text-xs">Based on analysis of 892 sources • Updated ${new Date().toLocaleString()}</p>
        `,
        'default': `
          <p><strong>Analysis: ${query}</strong></p>
          <p class="mt-3">Comprehensive intelligence assessment based on aggregated data sources:</p>
          <ul class="list-disc list-inside mt-3 space-y-2 text-vorenth-muted">
            <li><strong>Current Status:</strong> Active monitoring indicates moderate activity levels</li>
            <li><strong>Key Developments:</strong> Recent events suggest evolving dynamics in this space</li>
            <li><strong>Outlook:</strong> Near-term trajectory depends on multiple interconnected factors</li>
          </ul>
          <p class="mt-4"><strong>Confidence Level:</strong> <span class="text-vorenth-accent">High (87%)</span></p>
          <p class="mt-2 text-vorenth-muted text-xs">Based on analysis of ${Math.floor(Math.random() * 500) + 500} sources • Updated ${new Date().toLocaleString()}</p>
        `
      };

      const queryLower = query.toLowerCase();
      if (queryLower.includes('china') || queryLower.includes('taiwan')) {
        return templates.china;
      } else if (queryLower.includes('ai') || queryLower.includes('artificial intelligence') || queryLower.includes('regulation')) {
        return templates.ai;
      }
      return templates.default;
    }

    async function saveSearchResult() {
      if (!currentSearchResult || !currentSearchQuery) return;

      if (savedItems.length >= 999) {
        showToast('Maximum saved items limit reached', 'error');
        return;
      }

      const item = {
        id: `search-${Date.now()}`,
        type: 'search',
        title: currentSearchQuery,
        content: currentSearchResult.replace(/<[^>]*>/g, ' ').substring(0, 300),
        category: 'search',
        sentiment: 'neutral',
        relevance: 85,
        source: 'Deep Search',
        region: 'global',
        timestamp: new Date().toISOString(),
        saved: true
      };

      if (window.dataSdk) {
        const result = await window.dataSdk.create(item);
        if (result.isOk) {
          showToast('Search result saved!', 'success');
        } else {
          showToast('Failed to save result', 'error');
        }
      }
    }

    // ==================== Insight & Narrative Actions ====================
    async function toggleSaveInsight(id) {
      const insight = sampleInsights.find(i => i.id === id);
      if (!insight) return;

      const existingSaved = savedItems.find(s => s.id === id);

      if (existingSaved) {
        await removeSavedItem(existingSaved.__backendId);
      } else {
        if (savedItems.length >= 999) {
          showToast('Maximum saved items limit reached', 'error');
          return;
        }

        if (window.dataSdk) {
          const result = await window.dataSdk.create({ ...insight, saved: true });
          if (result.isOk) {
            showToast('Insight saved!', 'success');
          }
        }
      }
    }

    async function toggleSaveNarrative(id) {
      const narrative = sampleNarratives.find(n => n.id === id);
      if (!narrative) return;

      const existingSaved = savedItems.find(s => s.id === id);

      if (existingSaved) {
        await removeSavedItem(existingSaved.__backendId);
      } else {
        if (savedItems.length >= 999) {
          showToast('Maximum saved items limit reached', 'error');
          return;
        }

        if (window.dataSdk) {
          const item = {
            ...narrative,
            type: 'narrative',
            content: narrative.summary,
            saved: true
          };
          const result = await window.dataSdk.create(item);
          if (result.isOk) {
            showToast('Narrative saved!', 'success');
          }
        }
      }
    }

    async function removeSavedItem(backendId) {
      const item = savedItems.find(s => s.__backendId === backendId);
      if (!item || !window.dataSdk) return;

      const result = await window.dataSdk.delete(item);
      if (result.isOk) {
        showToast('Item removed', 'success');
      }
    }

    function viewInsight(id) {
      showToast('Opening insight details...', 'success');
    }

    function viewNarrative(id) {
      showToast('Opening narrative analysis...', 'success');
    }

    function filterInsights() {
      const filter = document.getElementById('insight-filter').value;
      showToast(`Filtering by: ${filter}`, 'success');
    }

    function filterNarratives() {
      const region = document.getElementById('narrative-region').value;
      showToast(`Showing: ${region === 'all' ? 'All regions' : region}`, 'success');
    }

    function generateNewInsight() {
      showToast('Generating new AI insight...', 'success');
    }

    function refreshData() {
      const btn = document.getElementById('refresh-btn');
      btn.classList.add('animate-spin');

      setTimeout(() => {
        btn.classList.remove('animate-spin');
        showToast('Data refreshed', 'success');
        renderDashboard();
      }, 1000);
    }

    function saveAccount() {
      showToast('Account settings saved!', 'success');
    }

    // ==================== Utility Functions ====================
    function getCategoryIcon(category) {
      const icons = {
        geopolitical: 'globe',
        economic: 'trending-up',
        technology: 'cpu',
        security: 'shield'
      };
      return icons[category] || 'file-text';
    }

    function getCategoryBadgeBg(category) {
      const colors = {
        geopolitical: 'bg-blue-500/20 text-blue-400',
        economic: 'bg-green-500/20 text-green-400',
        technology: 'bg-purple-500/20 text-purple-400',
        security: 'bg-red-500/20 text-red-400'
      };
      return colors[category] || 'bg-gray-500/20 text-gray-400';
    }

    function getSentimentBg(sentiment) {
      const colors = {
        positive: 'bg-green-500/20',
        negative: 'bg-red-500/20',
        neutral: 'bg-blue-500/20'
      };
      return colors[sentiment] || 'bg-gray-500/20';
    }

    function getSentimentColor(sentiment) {
      const colors = {
        positive: 'text-green-400',
        negative: 'text-red-400',
        neutral: 'text-blue-400'
      };
      return colors[sentiment] || 'text-gray-400';
    }

    function getSentimentBadgeBg(sentiment) {
      const colors = {
        positive: 'bg-green-500/20 text-green-400',
        negative: 'bg-red-500/20 text-red-400',
        neutral: 'bg-blue-500/20 text-blue-400'
      };
      return colors[sentiment] || 'bg-gray-500/20 text-gray-400';
    }

    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');

      const bgColor = type === 'success' ? 'bg-vorenth-success' : type === 'error' ? 'bg-vorenth-danger' : 'bg-vorenth-accent';

      toast.className = `${bgColor} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-2 slide-in`;
      toast.innerHTML = `
        <i data-lucide="${type === 'success' ? 'check-circle' : type === 'error' ? 'alert-circle' : 'info'}" class="w-4 h-4"></i>
        <span class="text-sm">${message}</span>
      `;

      container.appendChild(toast);
      lucide.createIcons();

      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(100%)';
        toast.style.transition = 'all 0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    // ==================== Initialize ====================
    initializeApp();
  </script>
